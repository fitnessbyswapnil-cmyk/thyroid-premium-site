  "PHASE_1_CRITICAL_FIXES": {
    "trigger_101_fix": {
      "name": "Block - Lead > 1 Firing",
      "current_condition": "{{js – Session Lead Fired}} == 'false'  ← WRONG",
      "fixed_condition": "{{js – Session Lead Fired}} == 'true'  ← Block WHEN already fired",
      "reason": "Blocking trigger activates when condition is TRUE. Current logic blocks BEFORE first firing. Fix: block when lead HAS been fired."
    },
    "trigger_106_fix": {
      "name": "Block - Lead Already Fired",
      "current_condition": "{{js – Session Lead Fired}} == 'false'  ← WRONG",
      "fixed_condition": "{{js – Session Lead Fired}} == 'true'",
      "reason": "Same inversion bug as trigger 101."
    },
    "tag_134_fix": {
      "name": "GA4 – Bundle Purchase",
      "action": "Remove trigger 158 from firingTriggerId",
      "keep": ["165"],
      "remove": ["158"],
      "reason": "Tag fires twice on success page: once on DOM Ready (158) and once on CE:purchase (165). Remove DOM Ready trigger."
    },
    "tag_131_fix": {
      "name": "Meta Pixel – ViewContent",
      "action": "Enable advancedMatching, add em/ph from localStorage JS variables",
      "advancedMatching": true,
      "advancedMatchingList": [
        {"name": "em", "value": "{{JS - user_email}}"},
        {"name": "ph", "value": "{{JS - user_phone}}"},
        {"name": "external_id", "value": "{{JS - visitor_id}}"}
      ]
    },
    "tag_96_fix": {
      "name": "Meta Pixel – Lead (Browser)",
      "action": "Enable advancedMatching",
      "advancedMatching": true,
      "advancedMatchingList": [
        {"name": "em", "value": "{{JS - user_email}}"},
        {"name": "ph", "value": "{{JS - user_phone}}"},
        {"name": "external_id", "value": "{{JS - visitor_id}}"}
      ]
    },
    "tag_153_fix": {
      "name": "HTML – Push metaUserData from Cookie",
      "action": "Fix cookie name mismatch",
      "current": "getCookie('useremail'), getCookie('userphone')",
      "fixed": "getCookie('user_email'), getCookie('user_phone')",
      "reason": "Tag 144 saves as user_email/user_phone but tag 153 reads useremail/userphone"
    }
  },

